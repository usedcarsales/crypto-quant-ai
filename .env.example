# crypto-quant AI — Environment Variables
# Copy to .env and fill in values before running Phase 5 (live execution)

# ============================================================
# PHASE 5: EXCHANGE API KEYS (required for live trading)
# ============================================================

# Binance — Spot + Futures
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Coinbase Advanced Trade
# Get from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=
COINBASE_SECRET_KEY=

# ============================================================
# DATA PROVIDERS (Phase 5+)
# ============================================================

# CoinGecko — free tier is rate-limited (10-30 calls/min)
# Upgrade at: https://www.coingecko.com/en/api pricing
COINGECKO_API_KEY=   # optional — premium key for higher rate limits

# CoinGlass — derivatives data
# https://coinglass.com
COINGLASS_API_KEY=

# DeFiLlama — free, no key required
# Already used via free tier in defi_scanner.py

# ============================================================
# NOTIFICATION / ALERTS
# ============================================================

# Discord webhook (optional — for trade alerts)
DISCORD_WEBHOOK_URL=

# ============================================================
# INTERNAL (do not commit)
# ============================================================

# OpenAI / Anthropic keys are managed by OpenClaw config
# GitHub token is in ~/.openclaw/workspace/TOOLS.md
